# CRE Sales Intelligence local demo configuration

# Backend
APP_NAME="CRE Sales Intelligence"
DATABASE_URL="sqlite:///./cre_sales_intelligence.db"
BACKEND_CORS_ORIGINS="http://localhost:3000"

# API keys (do not commit real secrets)
# EDINET_API_KEY is required only when fetching securities reports from EDINET.
EDINET_API_KEY=
# OPENAI_API_KEY is required only when IR_ANALYSIS_MODE=openai should call OpenAI API.
OPENAI_API_KEY=

# Phase 4B IR fetch/analyze pipeline
IR_FETCH_ENABLED=false
IR_FETCH_DRY_RUN=true
IR_ANALYSIS_MODE=mock
IR_FETCH_STORAGE_DIR=./storage/ir_fetch

# Frontend
NEXT_PUBLIC_API_BASE_URL="http://localhost:8000/api"
